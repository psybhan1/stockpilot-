{
  "name": "stockpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:extension && next build",
    "build:extension": "node browser-extension/scripts/build-zip.mjs",
    "vercel-build": "prisma generate --schema prisma/schema.prisma && npm run build:extension && next build",
    "start": "next start",
    "launch": "npm run db:generate && npm run setup:local && npm run db:push && npm run dev",
    "lint": "eslint",
    "setup:local": "node scripts/setup-local.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:compile && npm run test:run",
    "test:compile": "node -e \"require('node:fs').rmSync('.test-build', { recursive: true, force: true })\" && tsc -p tsconfig.tests.json",
    "test:run": "node --test --test-concurrency=1 --test-isolation=none .test-build/src/modules/**/*.test.js .test-build/src/lib/**/*.test.js",
    "test:db": "node --env-file=.env scripts/test-quick-add.mjs",
    "test:bot-e2e": "node --env-file=.env --import tsx scripts/test-bot-e2e.mts",
    "test:ai-provider": "node --env-file=.env --import tsx scripts/test-ai-provider.mts",
    "test:credentials": "node --env-file=.env --import tsx scripts/test-credentials.mts",
    "test:cart-links": "node --import tsx scripts/test-cart-links.mts",
    "test:sniffer": "node --import tsx scripts/test-sniffer.mts",
    "test:agent-steps": "node --env-file=.env --import tsx scripts/test-agent-steps.mts",
    "test:product-metadata": "node --import tsx scripts/test-product-metadata.mts",
    "test:creative": "node --import tsx scripts/test-creative-inputs.mts",
    "test:restaurant-day": "node --env-file=.env --import tsx scripts/test-restaurant-day.mts",
    "test:extension": "node --import tsx scripts/test-extension-endpoints.mts",
    "test:invoice-ocr": "node --env-file=.env --import tsx scripts/test-invoice-ocr.mts",
    "smoke:invoice": "node --env-file=.env --import tsx scripts/smoke-invoice.mts",
    "test:margins": "node --env-file=.env --import tsx scripts/test-margin-dashboard.mts",
    "test:variance": "node --env-file=.env --import tsx scripts/test-variance.mts",
    "test:pricing": "node --env-file=.env --import tsx scripts/test-pricing.mts",
    "test:cafe": "node --env-file=.env --import tsx scripts/test-cafe-lifecycle.mts",
    "test:bot-nasty": "node --import tsx scripts/test-bot-nasty-inputs.mts",
    "test:all": "npm run test && npm run test:db && npm run test:bot-e2e && npm run test:ai-provider && npm run test:credentials && npm run test:cart-links && npm run test:sniffer && npm run test:agent-steps && npm run test:product-metadata && npm run test:creative && npm run test:restaurant-day && npm run test:extension && npm run test:invoice-ocr && npm run test:margins && npm run test:variance && npm run test:pricing",
    "test:watch": "npm run test",
    "test:e2e": "playwright test",
    "db:generate": "npm run db:generate:postgres && npm run db:generate:sqlite",
    "db:generate:postgres": "prisma generate --schema prisma/schema.prisma",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:push": "node scripts/db-push.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx src/jobs/worker.ts",
    "worker:dev": "tsx watch src/jobs/worker.ts",
    "worker:once": "tsx src/jobs/worker.ts --once",
    "postinstall": "node -e \"if(!process.env.VERCEL){require('child_process').execSync('npm run db:generate',{stdio:'inherit'})}else{require('child_process').execSync('npm run db:generate:postgres',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.0",
    "@sparticuz/chromium": "^147.0.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "puppeteer-core": "^24.41.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unzipper": "^0.12.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
