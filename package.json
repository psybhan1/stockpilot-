{
  "name": "stockpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma generate --schema prisma/schema.prisma && next build",
    "start": "next start",
    "launch": "npm run db:generate && npm run setup:local && npm run db:push && npm run dev",
    "lint": "eslint",
    "setup:local": "node scripts/setup-local.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:compile && npm run test:run",
    "test:compile": "node -e \"require('node:fs').rmSync('.test-build', { recursive: true, force: true })\" && tsc -p tsconfig.tests.json",
    "test:run": "node --test --test-concurrency=1 --test-isolation=none .test-build/src/modules/**/*.test.js",
    "test:watch": "npm run test",
    "test:e2e": "playwright test",
    "db:generate": "npm run db:generate:postgres && npm run db:generate:sqlite",
    "db:generate:postgres": "prisma generate --schema prisma/schema.prisma",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:push": "node scripts/db-push.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx src/jobs/worker.ts",
    "worker:dev": "tsx watch src/jobs/worker.ts",
    "worker:once": "tsx src/jobs/worker.ts --once",
    "postinstall": "node -e \"if(!process.env.VERCEL){require('child_process').execSync('npm run db:generate',{stdio:'inherit'})}else{require('child_process').execSync('npm run db:generate:postgres',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
