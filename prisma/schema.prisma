model AgentTask {
  id               String          @id @default(cuid())
  locationId       String
  supplierId       String?
  purchaseOrderId  String?
  type             AgentTaskType
  status           AgentTaskStatus
  title            String
  description      String
  input            Json?
  output           Json?
  requiresApproval Boolean         @default(true)
  lastAttemptAt    DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  location         Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  supplier         Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder    PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  steps            AgentTaskStep[]
}

/// Per-step progress log for the browser ordering agent. Each entry
/// records a single milestone (launch, login, search, add-to-cart,
/// cart view, etc.) with an optional screenshot blob. The /agent-
/// tasks/[id] live view polls this table so managers can watch the
/// agent work in real time instead of waiting for the final Telegram
/// summary. `sequence` drives deterministic ordering in the UI.
model AgentTaskStep {
  id          String    @id @default(cuid())
  agentTaskId String
  sequence    Int
  name        String
  status      String    // "running" | "ok" | "failed"
  notes       String?
  screenshot  Bytes?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  agentTask   AgentTask @relation(fields: [agentTaskId], references: [id], onDelete: Cascade)

  @@index([agentTaskId, sequence])
}

model JobRun {
  id          String    @id @default(cuid())
  locationId  String?
  type        JobType
  status      JobStatus @default(PENDING)
  payload     Json?
  lockedAt    DateTime?
  availableAt DateTime  @default(now())
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
}

model BotConnectRequest {
  id         String     @id @default(cuid())
  locationId String
  userId     String
  channel    BotChannel
  tokenHash  String     @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, consumedAt])
  @@index([locationId, channel, createdAt])
}

model BotMessageReceipt {
  id                String     @id @default(cuid())
  locationId        String?
  userId            String?
  channel           BotChannel
  externalMessageId String
  senderId          String
  senderDisplayName String?
  inboundText       String
  replyText         String?
  status            String     @default("RECEIVED")
  purchaseOrderId   String?
  orderNumber       String?
  metadata          Json?
  rawPayload        Json?
  processedAt       DateTime?
  createdAt         DateTime   @default(now())
  location          Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  user              User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([channel, externalMessageId])
  @@index([senderId, channel, createdAt])
}

model BotConversationState {
  id         String     @id @default(cuid())
  locationId String
  userId     String
  senderId   String
  channel    BotChannel
  workflow   String
  step       String
  data       Json       @default("{}")
  expiresAt  DateTime
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, senderId, channel])
  @@index([senderId, channel, expiresAt])
}

/// Per-tenant, per-channel notification & bot connection record.
/// Credentials are stored AES-256-GCM encrypted in credentialsEncrypted.
model LocationChannel {
  id                   String      @id @default(cuid())
  locationId           String
  channel              ChannelType
  enabled              Boolean     @default(false)
  /// Telegram chat_id (for sending messages to this location's manager group)
  telegramChatId       String?
  /// WhatsApp phone number in E.164 format
  whatsappPhone        String?
  /// Email address used for sending
  emailAddress         String?
  /// "smtp" | "gmail"
  emailProvider        String?
  /// AES-256-GCM encrypted JSON blob (tokens, secrets, SMTP password, etc.)
  credentialsEncrypted String?
  /// Short pairing code for Telegram and WhatsApp flows
  pairingCode          String?
  pairingExpiresAt     DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  location             Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, channel])
  @@index([pairingCode])
}

/// Weekly rollup of deliveries vs recipe-predicted usage per inventory
/// item. One row per item per ISO week. Never mutated after write —
/// this IS the source-of-truth history that calibration derives from.
///
/// Invariants:
///   - `weekStart` is the Sunday 00:00 UTC of the ISO week.
///   - `deliveredBase` sums receipts + positive count adjustments that
///     aren't waste-logs or deletions.
///   - `recipePredictedBase` sums POS_DEPLETION movements in the window
///     (i.e. what recipes claimed was consumed).
///   - `observedExcessBase` = delivered - predicted. Positive means the
///     café ordered more than the recipe says was needed → either waste
///     OR recipe under-predicts. Over many weeks, the signal stabilises.
model InventoryCalibrationWeek {
  id                   String        @id @default(cuid())
  locationId           String
  inventoryItemId      String
  weekStart            DateTime
  weekEnd              DateTime
  deliveredBase        Int
  recipePredictedBase  Int
  wasteLoggedBase      Int           @default(0)
  observedExcessBase   Int
  deliveryCount        Int           @default(0)
  salesCount           Int           @default(0)
  computedAt           DateTime      @default(now())
  location             Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  inventoryItem        InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, weekStart])
  @@index([locationId, weekStart])
}

/// A recipe-component adjustment the calibration engine suggests to
/// the manager based on multiple weeks of InventoryCalibrationWeek
/// data. Created in PENDING, transitions to APPLIED or DISMISSED.
///
/// evidenceJson carries the weekly rollup snapshots + stats the
/// suggestion was derived from — so the manager (or a future audit)
/// can see exactly why the system proposed this change. Confidence
/// is stored but NEVER shown in UI; it only gates whether the
/// suggestion surfaces at all.
model RecipeCalibrationSuggestion {
  id                      String                            @id @default(cuid())
  locationId              String
  recipeComponentId       String
  currentQuantityBase     Int
  suggestedQuantityBase   Int
  excessPct               Float
  weeksOfData             Int
  confidenceScore         Float
  status                  RecipeCalibrationSuggestionStatus @default(PENDING)
  rationalePlain          String
  evidenceJson            Json
  createdAt               DateTime                          @default(now())
  appliedAt               DateTime?
  appliedById             String?
  dismissedAt             DateTime?
  location                Location                          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  recipeComponent         RecipeComponent                   @relation(fields: [recipeComponentId], references: [id], onDelete: Cascade)
  appliedBy               User?                             @relation("CalibrationSuggestionAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)

  @@index([locationId, status])
  @@index([recipeComponentId])
}

enum RecipeCalibrationSuggestionStatus {
  PENDING
  APPLIED
  DISMISSED
  SUPERSEDED
}

/// Records which (canonical, duplicate) recipe pairs a manager has
/// told us to leave alone. The duplicate-detection scan skips any
/// pair (in either direction) already dismissed. Lets us re-surface
/// after 90 days in case the recipes drift enough that it's worth a
/// second look.
model RecipeDuplicateDismissal {
  id                  String   @id @default(cuid())
  locationId          String
  recipeAId           String
  recipeBId           String
  dismissedAt         DateTime @default(now())
  dismissedById       String?

  @@unique([locationId, recipeAId, recipeBId])
  @@index([locationId, dismissedAt])
}
