{
  "manifest_version": 3,
  "name": "StockPilot — Sign in helper",
  "version": "0.2.1",
  "description": "Sign in to Amazon/Costco/etc. on their real website, then push your session to StockPilot with one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "StockPilot — Save my login"
  },
  "permissions": ["cookies", "storage", "activeTab", "tabs"],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.co.uk/*",
    "*://*.costco.com/*",
    "*://*.costco.ca/*",
    "*://*.walmart.com/*",
    "*://*.walmart.ca/*",
    "*://*.target.com/*",
    "*://*.samsclub.com/*",
    "*://*.lcbo.com/*",
    "*://*.saq.com/*",
    "*://*.bevmo.com/*",
    "*://*.totalwine.com/*",
    "*://*.sysco.com/*",
    "*://*.usfoods.com/*",
    "*://*.restaurantdepot.com/*",
    "*://*.webstaurantstore.com/*",
    "*://*.instacart.com/*"
  ],
  "optional_host_permissions": ["*://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
