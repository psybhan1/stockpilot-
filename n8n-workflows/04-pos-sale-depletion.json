{
  "name": "04 - POS Sale Stock Depletion",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "pos-sale",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "POS Sale Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"ok\": true }",
        "options": {}
      },
      "id": "respond-ok",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [480, 180]
    },
    {
      "parameters": {
        "url": "={{ $env.STOCKBUDDY_BASE_URL }}/api/n8n/record-sale",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-StockPilot-Webhook-Secret", "value": "={{ $env.STOCKBUDDY_WEBHOOK_SECRET }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "saleEventId", "value": "={{ ($json.body ?? $json).saleEventId }}" }
          ]
        },
        "options": {}
      },
      "id": "process-sale",
      "name": "Process Sale → Deduct Stock",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 380]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "success-check",
              "leftValue": "={{ $json.ok }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "id": "check-success",
      "name": "Success?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [720, 380]
    },
    {
      "parameters": {
        "authentication": "credentials",
        "chatId": "={{ $env.MANAGER_TELEGRAM_CHAT_ID }}",
        "text": "⚠️ Failed to process POS sale `{{ ($('POS Sale Webhook').first().json.body ?? $('POS Sale Webhook').first().json).saleEventId }}`. Check your StockBuddy logs.",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "notify-failure",
      "name": "Notify Failure",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [960, 480]
    }
  ],
  "connections": {
    "POS Sale Webhook": {
      "main": [
        [
          { "node": "Respond OK", "type": "main", "index": 0 },
          { "node": "Process Sale → Deduct Stock", "type": "main", "index": 0 }
        ]
      ]
    },
    "Process Sale → Deduct Stock": {
      "main": [[{ "node": "Success?", "type": "main", "index": 0 }]]
    },
    "Success?": {
      "main": [
        [],
        [{ "node": "Notify Failure", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "stockbuddy" }]
}
